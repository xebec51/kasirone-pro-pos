# PostgreSQL connection string (Neon or any Postgres provider).
# Example: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/kasirone_pro?sslmode=require"

# Base URL of the deployed app (used by NextAuth for callback URLs).
NEXTAUTH_URL="http://localhost:3000"

# Public-facing app URL, exposed to the client bundle.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Secret used to sign NextAuth JWTs/session cookies.
# Generate one with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-32-byte-base64-secret"

# Kept for compatibility with tooling that reads AUTH_SECRET instead of NEXTAUTH_SECRET.
AUTH_SECRET="replace-with-a-random-32-byte-base64-secret"
